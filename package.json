{
  "name": "simple-v2",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/simple*",
    "services/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:ci": "eslint .",
    "dev:simpleadmin": "pnpm --filter=@simple/simpleadmin run dev",
    "dev:simpleplataforma": "pnpm --filter=@simple/simpleplataforma run dev",
    "dev:autos": "pnpm --filter=@simple/autos run dev",
    "dev:propiedades": "pnpm --filter=@simple/propiedades run dev",
    "dev:agenda": "pnpm --filter=@simple/agenda run dev",
    "dev:serenatas": "pnpm --filter=@simple/serenatas run dev",
    "dev:api": "pnpm --filter=@simple/api run dev",
    "dev:all": "concurrently --kill-others-on-fail --names simpleadmin,simpleplataforma,simpleautos,simplepropiedades,simpleagenda,simpleserenatas,api --prefix-colors magenta,yellow,cyan,green,teal,red,blue \"pnpm --filter=@simple/simpleadmin run dev\" \"pnpm --filter=@simple/simpleplataforma run dev\" \"pnpm --filter=@simple/autos run dev\" \"pnpm --filter=@simple/propiedades run dev\" \"pnpm --filter=@simple/agenda run dev\" \"pnpm --filter=@simple/serenatas run dev\" \"pnpm --filter=@simple/api run dev\"",
    "build": "pnpm -r run build",
    "build:autos": "pnpm --filter=@simple/autos run build",
    "db:generate": "pnpm --filter=@simple/api run db:generate",
    "db:migrate": "pnpm --filter=@simple/api run db:migrate",
    "db:seed": "pnpm --filter=@simple/api run db:seed",
    "typecheck": "pnpm -r --if-present run typecheck",
    "check": "pnpm run lint:ci && pnpm run typecheck"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.17",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "ts-morph": "^28.0.0",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
