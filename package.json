{
  "name": "simple-v2",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/simple*",
    "services/*"
  ],
  "scripts": {
    "//ports": "3000=simpleadmin, 3001=simpleplataforma, 3002=autos, 3003=propiedades, 3004=agenda, 3005=serenatas, 4000=api",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "dev:simpleadmin": "pnpm --filter=@simple/simpleadmin run dev",
    "dev:simpleplataforma": "pnpm --filter=@simple/simpleplataforma run dev",
    "dev:autos": "pnpm --filter=@simple/autos run dev",
    "dev:propiedades": "pnpm --filter=@simple/propiedades run dev",
    "dev:agenda": "pnpm --filter=@simple/agenda run dev",
    "dev:serenatas": "pnpm --filter=@simple/serenatas run dev",
    "dev:api": "pnpm --filter=@simple/api run dev",
    "dev:all": "concurrently --kill-others-on-fail --names simpleadmin,simpleplataforma,simpleautos,simplepropiedades,simpleagenda,simpleserenatas,api --prefix-colors magenta,yellow,cyan,green,teal,orange,blue \"pnpm --filter=@simple/simpleadmin run dev\" \"pnpm --filter=@simple/simpleplataforma run dev\" \"pnpm --filter=@simple/autos run dev\" \"pnpm --filter=@simple/propiedades run dev\" \"pnpm --filter=@simple/agenda run dev\" \"pnpm --filter=@simple/serenatas run dev\" \"pnpm --filter=@simple/api run dev\"",
    "build": "pnpm -r run build",
    "build:autos": "pnpm --filter=@simple/autos run build",
    "build:serenatas": "pnpm --filter=@simple/serenatas run build",
    "db:generate": "pnpm --filter=@simple/api run db:generate",
    "db:migrate": "pnpm --filter=@simple/api run db:migrate",
    "db:seed": "pnpm --filter=@simple/api run db:seed"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.2.1",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
