# ─────────────────────────────────────────────────────────────────────────────
# SimplePlataforma — Variables de entorno
# Copia este archivo a .env.local y completa los valores reales
# Puerto de desarrollo: 3001
# ─────────────────────────────────────────────────────────────────────────────

# ── API ───────────────────────────────────────────────────────────────────────
# Producción (Coolify): NEXT_PUBLIC_API_URL vacío + API_INTERNAL_URL=https://api.simpleplataforma.app
NEXT_PUBLIC_API_URL=http://localhost:4000
API_INTERNAL_URL=http://localhost:4000

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_APP_ID=simpleplataforma
NEXT_PUBLIC_ADMIN_URL=http://localhost:3000
