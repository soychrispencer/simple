# ─────────────────────────────────────────────────────────────────────────────
# SimplePropiedades — Variables de entorno
# Copia este archivo a .env.local y completa los valores reales
# Puerto de desarrollo: 3003
# ─────────────────────────────────────────────────────────────────────────────

# ── API ───────────────────────────────────────────────────────────────────────
# Desarrollo: ambas apuntan al API local.
# Producción (Coolify): NEXT_PUBLIC_API_URL vacío + API_INTERNAL_URL=https://api.simpleplataforma.app
#   → el browser usa /api same-origin (cookies de sesión en simplepropiedades.app).
NEXT_PUBLIC_API_URL=http://localhost:4000
API_INTERNAL_URL=http://localhost:4000

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3003
NEXT_PUBLIC_APP_ID=simplepropiedades

# ── Google Maps ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=

# ── Google AI (Gemini) ────────────────────────────────────────────────────────
GOOGLE_AI_API_KEY=

# ── Mercado Pago ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=APP_USR-cc536e87-a22e-4f8d-8f41-a340c0a9c51e
