NEXT_PUBLIC_API_URL=http://localhost:4000

# Google Maps en navegador.
# Usa una browser key restringida por referrer para localhost.
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=tu_browser_key

# Vista previa embebida de Google Maps.
# Para desarrollo local puedes reutilizar la misma browser key
# si esa key tiene habilitada Maps Embed API.
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=tu_browser_key

# Mercado Pago para el frontend.
NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=tu_public_key
