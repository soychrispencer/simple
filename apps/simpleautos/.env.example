# URL del backend API (requerido)
# Producción: https://api.simpleplataforma.app
NEXT_PUBLIC_API_URL=http://localhost:4000

# URL pública de esta app, usada en sitemap.xml y robots.txt
NEXT_PUBLIC_APP_URL=https://simpleautos.cl

# Google AI — para generación de títulos y descripciones con IA (publicación rápida)
# Obtener en: https://aistudio.google.com/app/apikey (gratis)
# Si no se configura, se usa texto generado automáticamente sin IA.
GOOGLE_AI_API_KEY=AIza...

# Google Maps / Places — para autocompletado de direcciones (opcional)
# Si no se configura, el ingreso de dirección funciona sin sugerencias automáticas.
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=AIza...
