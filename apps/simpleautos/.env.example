# ─────────────────────────────────────────────────────────────────────────────
# SimpleAutos — Variables de entorno
# Copia este archivo a .env.local para desarrollo local.
# En producción (Coolify) configura cada variable en el panel de tu servicio.
#
# IMPORTANTE: Las variables NEXT_PUBLIC_* se hornean en el build.
# Si las cambias en Coolify debes hacer redeploy completo (no solo restart).
# ─────────────────────────────────────────────────────────────────────────────

# ── API Backend ────────────────────────────────────────────────────────────────
# ⚠️  Requerido. URL pública del contenedor API.
# Desarrollo: http://localhost:4000
# Producción: https://api.simpleplataforma.app
NEXT_PUBLIC_API_URL=https://api.simpleplataforma.app

# ── URL pública de esta app ────────────────────────────────────────────────────
# Usada en sitemap.xml, robots.txt, Open Graph y links de compartir.
NEXT_PUBLIC_APP_URL=https://simpleautos.app

# ── Google AI (generación de títulos y descripciones con IA) ──────────────────
# ⚠️  Requerido para la generación automática de texto en publicaciones.
# Obtener en: https://aistudio.google.com/app/apikey (plan gratuito disponible)
# Nota: esta variable es SERVER-SIDE (no lleva NEXT_PUBLIC_).
GOOGLE_AI_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
