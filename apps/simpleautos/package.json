{
  "name": "@simple/autos",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --port 3002",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "seed:catalog": "node scripts/seed-sql-to-catalog.mjs",
    "seed:catalog:internet": "powershell -ExecutionPolicy Bypass -File scripts/sync-internet-catalog.ps1",
    "seed:catalog:excel": "powershell -ExecutionPolicy Bypass -File scripts/merge-excel-catalog.ps1 -SourceXlsxPath \"$env:CATALOGO_XLSX_PATH\""
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@simple/auth": "workspace:*",
    "@simple/config": "workspace:*",
    "@simple/marketplace-header": "workspace:*",
    "@simple/types": "workspace:*",
    "@simple/ui": "workspace:*",
    "@simple/utils": "workspace:*",
    "@tabler/icons-react": "^3.44.0",
    "leaflet": "^1.9.4",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-leaflet": "^5.0.0",
    "swiper": "^12.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.19.21",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.3"
  }
