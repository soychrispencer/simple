# ─────────────────────────────────────────────────────────────────────────────
# simpleagenda — variables de entorno
# Copia este archivo a .env.local y completa los valores reales
# Puerto de desarrollo: 3004
# ─────────────────────────────────────────────────────────────────────────────

# ── API ───────────────────────────────────────────────────────────────────────
# URL del backend accesible desde el browser
NEXT_PUBLIC_API_URL=http://localhost:4000
# URL interna del backend para llamadas SSR (server-side). Puede diferir en prod.
API_INTERNAL_URL=http://localhost:4000

# ── App ───────────────────────────────────────────────────────────────────────
# URL pública de esta app (links de reserva, SEO, schema.org)
NEXT_PUBLIC_APP_URL=http://localhost:3004

# ── Google Maps — Places Autocomplete ────────────────────────────────────────
# Browser key con "Places API" habilitada.
# Google Console → Credenciales → Restricciones de referrer HTTP:
#   localhost:*          (desarrollo)
#   simpleagenda.cl/*    (producción)
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=

# ── Google AI (Gemini) ────────────────────────────────────────────────────────
# Genera políticas de cancelación con IA. Si está vacía usa texto predefinido.
# Obtener en: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=
