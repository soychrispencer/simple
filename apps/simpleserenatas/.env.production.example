# SimpleSerenatas — ejemplo de variables para producción

# URLs
NEXT_PUBLIC_APP_URL=https://simpleserenatas.app
NEXT_PUBLIC_SERENATAS_SITE_URL=https://simpleserenatas.app
NEXT_PUBLIC_APP_ID=simpleserenatas

# SEO / Search Console (opcional pero recomendado)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# API
NEXT_PUBLIC_API_URL=https://api.simpleserenatas.app
API_INTERNAL_URL=https://api.simpleserenatas.app

# Google Maps (frontend Places autocomplete)
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
