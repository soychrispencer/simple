# ─────────────────────────────────────────────────────────────────────────────
# SimpleSerenatas — Variables de entorno
# Copia este archivo a .env.local y completa los valores reales.
# Puerto de desarrollo: 3005
# ─────────────────────────────────────────────────────────────────────────────

# ── API ───────────────────────────────────────────────────────────────────────
# Dejar vacío en dev para que el browser use same-origin (/api → rewrite a :4000).
# Si defines http://localhost:4000, auth y cookies van cross-origin y fallan más fácil.
NEXT_PUBLIC_API_URL=
API_INTERNAL_URL=http://127.0.0.1:4000

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3005
NEXT_PUBLIC_APP_ID=simpleserenatas

# ── Google login / vincular cuenta (services/api .env) ─────────────────────────
# GOOGLE_REDIRECT_URI en la API puede ser:
#   http://localhost:4000/api/auth/google/callback  (la API redirige a Mi cuenta con avisos)
#   http://localhost:3005/auth/google/callback      (página Next; POST a la API para login)
# Enlazar Google desde Datos personales usa returnTo absoluto → /panel/cuenta?account_tab=data

# ── Google Calendar (Integraciones en Mi cuenta; OAuth vía API) ───────────────
# Mismas credenciales que login Google en services/api (.env): GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET.
# En Google Cloud Console, redirect URI autorizado:
#   http://localhost:4000/api/serenatas/google-calendar/callback
# (y el equivalente en producción con tu API_BASE_URL).
# La API usa SERENATAS_APP_URL para volver a /panel/cuenta?account_tab=integrations tras OAuth.

# ── Google Maps (libro de direcciones, Places) ────────────────────────────────
# Browser key con "Places API" y "Maps JavaScript API" habilitadas.
# Restricciones de referrer: localhost:* y tu dominio de producción.
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=
# Fallback si no defines BROWSER_KEY (misma key u otra con Places habilitado)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ── Mercado Pago (Suscripción Pro) ────────────────────────────────────────────
# La integración vive en services/api/.env.local, no en esta app:
#   MERCADO_PAGO_ACCESS_TOKEN=...
#   MERCADO_PAGO_PUBLIC_ORIGIN_SERENATAS=http://localhost:3005
#   MERCADO_PAGO_DEV_CHECKOUT_FALLBACK=true   # true = activa Pro sin ir a MP (solo dev)
#   MERCADO_PAGO_DEV_CHECKOUT_FALLBACK=false  # + túnel HTTPS en ORIGIN_SERENATAS = pago real en local
# Reinicia la API (:4000) tras cambiar esas variables.

# ── E2E Playwright (opcional) ─────────────────────────────────────────────────
# Smoke local (API :4000 + app :3005): pnpm --filter @simple/serenatas test:e2e
# CI / E2E real con Chromium: pnpm --filter @simple/serenatas test:e2e:real
# Smoke CI sin browsers: pnpm --filter @simple/serenatas test:e2e:ci  (PLAYWRIGHT_SKIP=1 en job e2e-serenatas)
# Omitir browsers en pipeline: PLAYWRIGHT_SKIP=1 pnpm --filter @simple/serenatas test:e2e:ci
# Seed usuario+grupo demo: pnpm --filter @simple/api run db:seed:serenatas-e2e
# Luego copiar SERENATAS_E2E_EMAIL / SERENATAS_E2E_PASSWORD que imprime el script
# GitHub Actions: job e2e-serenatas-real si existe secret E2E_TEST_EMAIL (o SERENATAS_E2E_EMAIL).
# Fixture login: e2e/helpers/auth.ts (loginSerenatasSession).
# Sin credenciales: solo smoke públicos. Con credenciales: panel, marketplace y admin (solicitudes / mi-negocio).
SERENATAS_E2E_EMAIL=usuario-verificado@ejemplo.cl
SERENATAS_E2E_PASSWORD=contraseña-segura-e2e
# E2E_TEST_EMAIL=usuario-verificado@ejemplo.cl
# E2E_TEST_PASSWORD=contraseña-segura-e2e
# API para login en setup E2E (default: http://localhost:4000)
E2E_API_URL=http://localhost:4000
