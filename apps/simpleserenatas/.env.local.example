# ─────────────────────────────────────────────────────────────────────────────
# SimpleSerenatas — Variables de entorno
# Copia este archivo a .env.local y completa los valores reales
# Puerto de desarrollo: 3005
# ─────────────────────────────────────────────────────────────────────────────

# ── API ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
API_INTERNAL_URL=http://localhost:4000

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3005
# Opcional: URL canónica solo para SEO/sitemap/OG (si difiere de APP_URL en edge cases)
# NEXT_PUBLIC_SERENATAS_SITE_URL=https://tu-dominio.cl
# Opcional: token de verificación Google Search Console (meta tag automático en layout)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_APP_ID=simpleserenatas

# ── Google Maps (frontend Places autocomplete) ────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
