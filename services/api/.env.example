# ─────────────────────────────────────────────────────────────────────────────
# SimpleAutos API — Variables de entorno
# Copia este archivo a .env.local para desarrollo local.
# En producción (Coolify) configura cada variable en el panel de tu servicio.
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de datos ─────────────────────────────────────────────────────────────
# Requerido. PostgreSQL.
# Prod: usa la URL interna de tu DB en Coolify (sin pasar por internet).
DATABASE_URL=postgres://postgres:password@localhost:5432/simplev2

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=4000
API_HOST=0.0.0.0

# ── CORS ──────────────────────────────────────────────────────────────────────
# Lista de orígenes permitidos, separados por coma.
# En desarrollo local se permiten localhost:3000-3005 automáticamente.
# En producción DEBES configurar los dominios reales de tus frontends.
CORS_ORIGINS=https://simpleautos.cl,https://www.simpleautos.cl,https://simpleplataforma.app,https://www.simpleplataforma.app

# ── Autenticación ─────────────────────────────────────────────────────────────
# SESSION_SECRET: clave para firmar JWT. Debe ser larga y aleatoria. NO cambiar en prod.
SESSION_SECRET=oKj21fyjOK1dK37THJgDL+o85MYT55MY1/P/2SRtQ0pDJ540Hdg21RHuBzs4B9/zmIBujNcYFBmDltG1Oze7Xg==

# AUTH_COOKIE_SAMESITE: en producción con dominios separados debe ser 'none'.
# Requiere HTTPS en el frontend y Secure en la cookie.
AUTH_COOKIE_SAMESITE=none

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Requerido para login con Google.
# Obtener en: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=625654759964-oc21lg0tmk1sk1ce8stfjte5oovjocug.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Storage — Backblaze B2 (modo S3) ─────────────────────────────────────────
# Requerido para subida de imágenes.
# Backblaze B2 con S3-compatible API (recomendado).
STORAGE_PROVIDER=backblaze-s3
BACKBLAZE_S3_ENDPOINT=https://s3.us-east-005.backblazeb2.com
BACKBLAZE_S3_REGION=us-east-5
BACKBLAZE_S3_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
BACKBLAZE_S3_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BACKBLAZE_BUCKET_NAME=simple-media
BACKBLAZE_DOWNLOAD_URL=https://f17974d3ed5953ca39fdc0617.backblazeb2.com

# Alternativa: Backblaze B2 con API nativa (requiere BACKBLAZE_BUCKET_ID adicional)
# STORAGE_PROVIDER=backblaze-b2
# BACKBLAZE_APP_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxx
# BACKBLAZE_APP_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# BACKBLAZE_BUCKET_ID=xxxxxxxxxxxxxxxxxxxxxxxx
# BACKBLAZE_BUCKET_NAME=simple-media
# BACKBLAZE_DOWNLOAD_URL=https://f17974d3ed5953ca39fdc0617.backblazeb2.com

# ── Google Maps (geocodificación server-side) ─────────────────────────────────
# Opcional. Para geocodificar direcciones en el backend.
# Restringir a IP del servidor en Google Cloud Console.
GOOGLE_MAPS_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GOOGLE_GEOCODING_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── SMTP (recuperación de contraseña) ─────────────────────────────────────────
# Opcional. Si no se configura, el reset de contraseña no funcionará.
# Recomendado: Brevo (ex-Sendinblue), plan gratuito suficiente.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_email@dominio.com
SMTP_PASSWORD=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SMTP_FROM=Simple <noreply@simpleautos.cl>

# ── Mercado Pago (suscripciones y pagos) ──────────────────────────────────────
# Opcional. Necesario solo si usas pagos en la plataforma.
# Access Token de producción (empieza con APP_USR-).
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxxxxx

# URLs públicas de los frontends para redirects de Mercado Pago.
# Coolify expone cada app en su propio dominio.
MERCADO_PAGO_PUBLIC_ORIGIN_AUTOS=https://simpleautos.cl
MERCADO_PAGO_PUBLIC_ORIGIN_PROPIEDADES=https://simplepropiedades.cl

# ── SimpleAgenda — Mercado Pago OAuth marketplace ─────────────────────────────
# Opcional. Para pagos directos al profesional (marketplace).
MP_AGENDA_APP_ID=tu_app_id_mercadopago
MP_AGENDA_APP_SECRET=tu_app_secret_mercadopago

# URL base del API y del frontend de SimpleAgenda (para callbacks OAuth)
API_BASE_URL=https://api.simpleplataforma.app
AGENDA_APP_URL=https://agenda.simpleplataforma.app

# ── Admin bootstrap (solo desarrollo) ─────────────────────────────────────────
# En producción debe ser false. Solo activa en dev para crear el primer superadmin.
ENABLE_ADMIN_BOOTSTRAP=false
