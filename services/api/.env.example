# ─────────────────────────────────────────────────────────────────────────────
# simple-api — variables de entorno (plantilla producción / referencia)
# Desarrollo local: copia .env.local.example → .env.local (STORAGE_PROVIDER=local, etc.)
# ─────────────────────────────────────────────────────────────────────────────

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=4000
API_HOST=0.0.0.0
API_BASE_URL=http://localhost:4000

# ── Base de datos ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/simple

# ── CORS ──────────────────────────────────────────────────────────────────────
# Orígenes permitidos separados por coma (apps locales: 3000-3005; :3005 = SimpleSerenatas)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost:3005

# ── Autenticación ─────────────────────────────────────────────────────────────
SESSION_SECRET=
AUTH_COOKIE_SAMESITE=lax

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Requerido para login con Google.
# Obtener en: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
# Puede apuntar al API o al callback frontend de cada app (solo desarrollo local).
# ⚠️ En producción NO definir GOOGLE_REDIRECT_URI: cada app usa {origin}/auth/google/callback.
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
# Google Calendar (Serenatas → Mi cuenta → Integraciones):
# redirect_uri = {SERENATAS_APP_URL}/api/serenatas/google-calendar/callback
#   Local: http://localhost:3005/api/serenatas/google-calendar/callback
#   Prod:  https://simpleserenatas.app/api/serenatas/google-calendar/callback
# Google Calendar (Autos / Propiedades → Mi cuenta → Integraciones):
# redirect_uri = {APP_URL}/api/integrations/google-calendar/callback
#   Local Autos:        http://localhost:3002/api/integrations/google-calendar/callback
#   Local Propiedades:  http://localhost:3003/api/integrations/google-calendar/callback
# Registrar esas URIs en Google Cloud → OAuth client → Authorized redirect URIs.
# GOOGLE_SERENATAS_CALENDAR_REDIRECT_URI=   # opcional, override explícito
SERENATAS_APP_URL=http://localhost:3005

# ── Storage Provider ──────────────────────────────────────────────────────────
# Producción / staging: cloudflare-r2. Desarrollo: STORAGE_PROVIDER=local (.env.local)
STORAGE_PROVIDER=cloudflare-r2
# URL pública de archivos locales (solo si STORAGE_PROVIDER=local en dev)
# LOCAL_STORAGE_URL=http://localhost:4000/uploads

# ── Storage — Cloudflare R2 (producción) ─────────────────────────────────────
# Credenciales: Dashboard → R2 → Manage R2 API Tokens (Object Read & Write).
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=simple-media
# URL pública (*.r2.dev o custom domain). Obligatoria con STORAGE_PROVIDER=cloudflare-r2.
CLOUDFLARE_R2_PUBLIC_URL=

# ── Google Maps ───────────────────────────────────────────────────────────────
# Server: geocodificación (restringir por IP del servidor).
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY
# Browser: Places / sugerencias de dirección en frontends (restringir por referrer).
# Si no se define, los clientes pueden usar GOOGLE_MAPS_API_KEY vía /api/public/maps-browser-key.
GOOGLE_MAPS_BROWSER_KEY=

# ── SMTP (Brevo) ──────────────────────────────────────────────────────────────
# Remitente único para todas las verticales (auth, pagos, agenda, etc.).
# El asunto y el nombre visible pueden decir SimpleSerenatas / SimpleAutos según origin;
# el email From siempre es el de SMTP_FROM (dominio padre simpleplataforma.app).
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Simple <noreply@simpleplataforma.app>

# ── Mercado Pago ──────────────────────────────────────────────────────────────
MERCADO_PAGO_ACCESS_TOKEN=YOUR_MERCADO_PAGO_ACCESS_TOKEN
MERCADO_PAGO_WEBHOOK_SECRET=
# Solo desarrollo: aceptar webhooks sin firma HMAC (nunca en producción)
MERCADO_PAGO_WEBHOOK_ALLOW_UNSIGNED=
MERCADO_PAGO_PUBLIC_ORIGIN_AUTOS=http://localhost:3002
MERCADO_PAGO_PUBLIC_ORIGIN_PROPIEDADES=http://localhost:3003
MERCADO_PAGO_PUBLIC_ORIGIN_SERENATAS=http://localhost:3005
MERCADO_PAGO_PUBLIC_ORIGIN_AGENDA=http://localhost:3004
MERCADO_PAGO_DEV_CHECKOUT_FALLBACK=true

# Serenatas: false (default) bloquea POST /client/serenatas por paquetes legacy; marketplace sigue activo.
# true habilita contrato por paquetes + flujo de pago MP existente.
SERENATAS_LEGACY_PACKAGES=false

# ── SimpleAgenda — Mercado Pago OAuth ─────────────────────────────────────────
MP_AGENDA_APP_ID=YOUR_MP_AGENDA_APP_ID
MP_AGENDA_APP_SECRET=YOUR_MP_AGENDA_APP_SECRET
AGENDA_APP_URL=http://localhost:3004

# ── Web Push (VAPID) — SimpleAgenda (`pnpm exec web-push generate-vapid-keys`)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@simpleplataforma.app

# ── Instagram ─────────────────────────────────────────────────────────────────
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=https://api.simpleplataforma.app/api/integrations/instagram/callback

# ── TikTok ────────────────────────────────────────────────────────────────────
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://api.simpleplataforma.app/api/integrations/tiktok/callback

# ── YouTube Shorts (reutiliza credenciales Google) ────────────────────────────
YOUTUBE_REDIRECT_URI=https://api.simpleplataforma.app/api/integrations/youtube/callback

# ── Rate limit (opcional) ─────────────────────────────────────────────────────
# Si está definida, `lib/rate-limit.ts` (middleware Agenda, lectura pública, etc.) usa ioredis
# (optionalDependency) para contadores compartidos entre réplicas.
# `/api/auth/*` usa `lib/auth-rate-limit.ts` (Map local); complementar con proxy en producción.
# Sin REDIS_URL: Map en memoria por proceso + rate limit en proxy (COOLIFY_DEPLOYMENT.md).
REDIS_URL=

# ── Cron jobs ─────────────────────────────────────────────────────────────────
AGENDA_CRON_ENABLED=false

# ── Admin bootstrap ───────────────────────────────────────────────────────────
ENABLE_ADMIN_BOOTSTRAP=false
