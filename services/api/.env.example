# Geocodificación server-side.
# Usa una key separada de la del navegador.
# Idealmente restríngela por IP o por backend y limítala a Geocoding API.
GOOGLE_MAPS_API_KEY=tu_server_key

# Base de datos
DATABASE_URL=postgres://postgres:password@localhost:5432/simplev2

# Opcional: key separada solo para Geocoding API
# GOOGLE_GEOCODING_API_KEY=tu_geocoding_key

SESSION_SECRET=oKj21fyjOK1dK37THJgDL+o85MYT55MY1/P/2SRtQ0pDJ540Hdg21RHuBzs4B9/zmIBujNcYFBmDltG1Oze7Xg==
AUTH_COOKIE_SAMESITE=none

# SMTP opcional para recuperación de contraseña.
# En producción, si no configuras SMTP, la API rechazará la recuperación.
SMTP_HOST=smtp.tu-proveedor.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_usuario
SMTP_PASSWORD=tu_password
SMTP_FROM=Simple <no-reply@tu-dominio.com>

# Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN=tu_access_token
MERCADO_PAGO_CLIENT_ID=tu_client_id
MERCADO_PAGO_CLIENT_SECRET=tu_client_secret

# Para suscripciones desde desarrollo local necesitas una URL publica HTTPS
# que apunte a cada frontend. Ejemplos:
# MERCADO_PAGO_PUBLIC_ORIGIN_AUTOS=https://abc123.ngrok-free.app
# MERCADO_PAGO_PUBLIC_ORIGIN_PROPIEDADES=https://def456.ngrok-free.app
# Si ambas verticales usan la misma URL publica puedes usar solo:
# MERCADO_PAGO_PUBLIC_ORIGIN=https://abc123.ngrok-free.app
