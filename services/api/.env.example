# ─────────────────────────────────────────────────────────────────────────────
# simple-api — variables de entorno
# Copia este archivo a .env.local y completa los valores reales
# ─────────────────────────────────────────────────────────────────────────────

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=4000
API_HOST=0.0.0.0
API_BASE_URL=http://localhost:4000

# ── Base de datos ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/simplev2

# ── CORS ──────────────────────────────────────────────────────────────────────
# Orígenes permitidos separados por coma (apps locales: 3000-3005)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost:3005

# ── Autenticación ─────────────────────────────────────────────────────────────
SESSION_SECRET=
AUTH_COOKIE_SAMESITE=lax

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Requerido para login con Google.
# Obtener en: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
# Puede apuntar al API o al callback frontend de cada app.
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# ── Storage Provider ──────────────────────────────────────────────────────────
# Opciones: backblaze-s3 | cloudflare-r2
STORAGE_PROVIDER=backblaze-s3

# ── Storage — Backblaze B2 ────────────────────────────────────────────────────
BACKBLAZE_S3_ENDPOINT=https://s3.us-east-005.backblazeb2.com
BACKBLAZE_S3_REGION=us-east-5
BACKBLAZE_S3_ACCESS_KEY=
BACKBLAZE_S3_SECRET_KEY=
BACKBLAZE_BUCKET_NAME=simple-media
BACKBLAZE_DOWNLOAD_URL=https://f005.backblazeb2.com

# ── Google Maps (geocodificación server-side) ─────────────────────────────────
# Opcional. Restringir a IP del servidor en Google Cloud Console.
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# ── SMTP (Brevo) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Simple <noreply@simpleplataforma.app>

# ── Mercado Pago ──────────────────────────────────────────────────────────────
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=
MERCADO_PAGO_PUBLIC_ORIGIN_AUTOS=http://localhost:3002
MERCADO_PAGO_PUBLIC_ORIGIN_PROPIEDADES=http://localhost:3003
MERCADO_PAGO_PUBLIC_ORIGIN_SERENATAS=http://localhost:3005
MERCADO_PAGO_DEV_CHECKOUT_FALLBACK=true

# ── SimpleAgenda — Mercado Pago OAuth ─────────────────────────────────────────
MP_AGENDA_APP_ID=
MP_AGENDA_APP_SECRET=
AGENDA_APP_URL=http://localhost:3004

# ── Web Push (VAPID) — SimpleAgenda (`pnpm exec web-push generate-vapid-keys`)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@simpleplataforma.app

# ── WhatsApp (Meta Business) ──────────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_PHONE_NUMBER_ID_AUTOS=
WHATSAPP_PHONE_NUMBER_ID_PROPIEDADES=
WHATSAPP_PHONE_NUMBER_ID_AGENDA=

# ── Instagram ─────────────────────────────────────────────────────────────────
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=https://api.simpleplataforma.app/api/integrations/instagram/callback

# ── Cron jobs ─────────────────────────────────────────────────────────────────
AGENDA_CRON_ENABLED=false

# ── Admin bootstrap ───────────────────────────────────────────────────────────
ENABLE_ADMIN_BOOTSTRAP=false
