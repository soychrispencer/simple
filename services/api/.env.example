# ─────────────────────────────────────────────────────────────────────────────
# Simple API — Variables de entorno
# Copia este archivo a .env para desarrollo local.
# En producción (Coolify) configura cada variable en el panel de tu servicio.
# Las variables marcadas con ⚠️  son REQUERIDAS. Sin ellas el API no funciona.
# ─────────────────────────────────────────────────────────────────────────────

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=4000
API_HOST=0.0.0.0

# URL pública del API. Usada para construir URLs absolutas (imágenes, OAuth callbacks).
# ⚠️  En producción DEBE ser la URL real del contenedor (con HTTPS).
API_BASE_URL=https://api.simpleplataforma.app

# ── Base de datos ─────────────────────────────────────────────────────────────
# ⚠️  Requerido. PostgreSQL.
# Prod: usa la URL interna de tu DB en Coolify (sin pasar por internet).
DATABASE_URL=postgres://postgres:password@localhost:5432/simplev2

# ── CORS ──────────────────────────────────────────────────────────────────────
# ⚠️  Lista de orígenes permitidos separados por coma.
# En desarrollo local se permiten localhost:3000-3005 automáticamente.
CORS_ORIGINS=https://simpleautos.app,https://www.simpleautos.app,https://simplepropiedades.cl,https://www.simplepropiedades.cl,https://simpleplataforma.app,https://www.simpleplataforma.app,https://simpleagenda.app,https://www.simpleagenda.app,https://admin.simpleplataforma.app

# ── Autenticación ─────────────────────────────────────────────────────────────
# ⚠️  SESSION_SECRET: clave para firmar JWT. Debe ser larga y aleatoria. NO cambiar en prod.
SESSION_SECRET=cambia_esto_por_una_clave_aleatoria_larga_minimo_64_caracteres

# AUTH_COOKIE_SAMESITE: en producción con dominios separados DEBE ser 'none'.
# Requiere HTTPS. En desarrollo local usar 'lax'.
AUTH_COOKIE_SAMESITE=none

# ── Google OAuth ──────────────────────────────────────────────────────────────
# ⚠️  Requerido para login con Google.
# Obtener en: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=625654759964-oc21lg0tmk1sk1ce8stfjte5oovjocug.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Storage — Backblaze B2 (modo S3) ─────────────────────────────────────────
# ⚠️  Requerido para subida de imágenes.
STORAGE_PROVIDER=backblaze-s3
BACKBLAZE_S3_ENDPOINT=https://s3.us-east-005.backblazeb2.com
BACKBLAZE_S3_REGION=us-east-5
BACKBLAZE_S3_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
BACKBLAZE_S3_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BACKBLAZE_BUCKET_NAME=simple-media
BACKBLAZE_DOWNLOAD_URL=https://f005.backblazeb2.com

# ── Google Maps (geocodificación server-side) ─────────────────────────────────
# Opcional. Para geocodificar direcciones en el backend.
# Restringir a IP del servidor en Google Cloud Console.
GOOGLE_MAPS_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── SMTP (emails de sistema: reset de contraseña, verificación) ───────────────
# ⚠️  Requerido para que funcionen los emails transaccionales.
# Recomendado: Brevo (ex-Sendinblue), plan gratuito suficiente.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_email@smtp-brevo.com
SMTP_PASSWORD=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SMTP_FROM=Simple <noreply@simpleplataforma.app>

# ── Mercado Pago (suscripciones y pagos en marketplace) ───────────────────────
# ⚠️  Requerido si usas cobros. Access Token de producción (empieza con APP_USR-).
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxxxxx

# URLs públicas de cada app para redirects de Mercado Pago.
MERCADO_PAGO_PUBLIC_ORIGIN_AUTOS=https://simpleautos.app
MERCADO_PAGO_PUBLIC_ORIGIN_PROPIEDADES=https://simplepropiedades.cl

# ── SimpleAgenda — Mercado Pago OAuth marketplace ─────────────────────────────
# Requerido para que los profesionales conecten su cuenta de MP en SimpleAgenda.
# Obtener en: https://www.mercadopago.com.ar/developers/panel/app
MP_AGENDA_APP_ID=tu_app_id_mercadopago
MP_AGENDA_APP_SECRET=tu_app_secret_mercadopago

# URL pública del frontend de SimpleAgenda (para callbacks OAuth de MP y Google).
AGENDA_APP_URL=https://simpleagenda.app

# ── WhatsApp — Meta Cloud API ─────────────────────────────────────────────────
# Opcional. Para notificaciones vía WhatsApp.
# Obtener en: https://developers.facebook.com → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Phone Number IDs por vertical (usar el mismo si solo hay uno):
WHATSAPP_PHONE_NUMBER_ID=xxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID_AUTOS=xxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID_PROPIEDADES=xxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID_AGENDA=xxxxxxxxxxxxxxxxx

# ── Instagram / Meta (publicación directa desde el panel) ─────────────────────
# Requerido para que usuarios Pro/Empresa publiquen en Instagram.
# Crear app en: https://developers.facebook.com → My Apps → Create App
# Tipo: Business. Agregar producto "Instagram Login for Business".
# IMPORTANTE: usar el Instagram App ID (no el Facebook App ID).
# En Meta Developers: Instagram → API setup with Instagram login for Business
# El Instagram App ID y Secret están en esa sección, NO en la configuración general.
# Registrar INSTAGRAM_REDIRECT_URI en: Valid OAuth Redirect URIs de la app.
#
# ⚠️  INSTAGRAM_REDIRECT_URI debe ser HTTPS y coincidir exactamente con lo
# registrado en el panel de Meta Developers. En dev usar Cloudflare Tunnel.
INSTAGRAM_APP_ID=xxxxxxxxxxxxxxxx
INSTAGRAM_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
INSTAGRAM_REDIRECT_URI=https://api.simpleplataforma.app/api/integrations/instagram/callback
# INSTAGRAM_API_VERSION=v24.0   # opcional, default v24.0

# ── Lead Ingest (webhook externo de leads) ────────────────────────────────────
# Opcional. Si se configura, habilita el endpoint POST /api/leads/ingest.
# LEAD_INGEST_SECRET=una_clave_secreta_para_el_webhook

# ── Admin bootstrap ───────────────────────────────────────────────────────────
# ⚠️  DEBE ser false en producción.
# Solo activar en dev para crear el primer superadmin.
ENABLE_ADMIN_BOOTSTRAP=false

# ── SimpleAgenda Development ────────────────────────────────────────────────────
# Control para activar cron jobs de SimpleAgenda en desarrollo.
# En producción se activan automáticamente. En desarrollo solo si AGENDA_CRON_ENABLED=true
# AGENDA_CRON_ENABLED=true
