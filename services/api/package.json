{
    "name": "@simple/api",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "postinstall": "node ../../scripts/ensure-ffmpeg.mjs",
        "ensure:ffmpeg": "node ../../scripts/ensure-ffmpeg.mjs",
        "build": "tsc",
        "typecheck": "tsc --noEmit",
        "start": "node dist/server.js",
        "db:seed": "tsx scripts/seed-admin-users.ts",
        "db:seed:marketplace": "tsx scripts/seed-marketplace-staging.ts",
        "db:seed:serenatas-demo": "tsx scripts/seed-serenatas-marketplace-demo.ts",
        "db:seed:admin-demos": "tsx scripts/seed-admin-public-demos.ts",
        "db:seed:serenatas-e2e": "tsx scripts/seed-serenatas-e2e.ts",
        "db:cleanup:serenatas-dual-clients": "tsx scripts/cleanup-serenatas-dual-client-profiles.ts",
        "db:repair:marketplace": "tsx scripts/repair-marketplace-schema.ts",
        "db:apply:post-journal": "tsx scripts/apply-post-journal-migrations.ts",
        "db:setup": "pnpm run db:migrate && pnpm run db:apply:post-journal && pnpm run db:sync:migration-hashes",
        "db:seed:smoke-toyota": "tsx scripts/seed-smoke-listing-toyota.ts",
        "db:sync:migration-hashes": "tsx scripts/sync-drizzle-migration-hashes.ts",
        "smoke:marketplace": "tsx scripts/smoke-marketplace.ts",
        "test": "vitest run --config vitest.config.ts",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:push": "drizzle-kit push",
        "db:studio": "drizzle-kit studio",
        "user:promote-admin": "tsx scripts/promote-user-to-admin.ts",
        "db:clean": "tsx scripts/clean-db.ts",
        "mercadopago:verify": "tsx scripts/verify-mercadopago.ts"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1076.0",
        "@google/generative-ai": "^0.24.1",
        "@hono/node-server": "^2.0.6",
        "@hono/oauth-providers": "^0.8.5",
        "@simple/config": "workspace:*",
        "@simple/logger": "workspace:*",
        "@simple/types": "workspace:*",
        "@simple/utils": "workspace:*",
        "bcryptjs": "^3.0.3",
        "drizzle-orm": "^0.45.2",
        "ffmpeg-static": "^5.3.0",
        "googleapis": "^173.0.0",
        "hono": "^4.12.27",
        "jsonwebtoken": "^9.0.3",
        "node-cron": "^4.5.0",
        "nodemailer": "^9.0.1",
        "postgres": "^3.4.9",
        "sharp": "^0.35.2",
        "web-push": "^3.6.7",
        "zod": "^4.4.3"
    },
    "optionalDependencies": {
        "ioredis": "^5.11.1"
    },
    "devDependencies": {
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^26.0.1",
        "@types/node-cron": "^3.0.11",
        "@types/nodemailer": "^8.0.1",
        "drizzle-kit": "^0.31.10",
        "@types/web-push": "^3.6.4",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3"
    }
}
