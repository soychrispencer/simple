# ==========================================
# Cloudflare R2 Storage (Reemplaza Backblaze)
# ==========================================
# Storage provider: 'cloudflare-r2' | 'backblaze-b2' | 'backblaze-s3' | 'local'
STORAGE_PROVIDER=cloudflare-r2

# Cloudflare R2 Configuration
# Obtén estos valores desde: https://dash.cloudflare.com → R2 → Manage R2 API Tokens
CLOUDFLARE_R2_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_R2_ACCESS_KEY_ID=your_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_secret_access_key
CLOUDFLARE_R2_BUCKET_NAME=simple-media

# URL pública del bucket (configurada en R2)
# Puede ser: https://pub-xxx.r2.dev (R2.dev) o tu dominio custom
CLOUDFLARE_R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ==========================================
# Cloudflare Worker (Generación de imágenes Instagram)
# ==========================================
# URL del Worker que genera overlays (desplegado desde infrastructure/cloudflare/workers/instagram-overlay)
CLOUDFLARE_WORKER_URL=https://simple-instagram-overlay.tu-subdominio.workers.dev

# ==========================================
# Cloudflare Images (Opcional - para optimización automática)
# ==========================================
# Solo si usas Cloudflare Images además de R2
CLOUDFLARE_IMAGES_ACCOUNT_ID=your_account_id
CLOUDFLARE_IMAGES_API_TOKEN=your_api_token

# ==========================================
# Instagram API (sin cambios)
# ==========================================
INSTAGRAM_APP_ID=your_instagram_app_id
INSTAGRAM_APP_SECRET=your_instagram_app_secret
INSTAGRAM_REDIRECT_URI=https://tu-dominio.com/api/integrations/instagram/callback
INSTAGRAM_API_VERSION=v21.0

# ==========================================
# Legacy: Backblaze (solo si usas STORAGE_PROVIDER=backblaze-*)
# ==========================================
# BACKBLAZE_APP_KEY_ID=
# BACKBLAZE_APP_KEY=
# BACKBLAZE_BUCKET_ID=
# BACKBLAZE_BUCKET_NAME=simple-media
# BACKBLAZE_DOWNLOAD_URL=https://f005.backblazeb2.com
# BACKBLAZE_S3_ENDPOINT=
# BACKBLAZE_S3_ACCESS_KEY=
# BACKFLAZE_S3_SECRET_KEY=
