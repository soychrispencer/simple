# ─────────────────────────────────────────────────────────────────────────────
# simple-api — variables de entorno
# Copia este archivo a .env.local y completa los valores reales
# ─────────────────────────────────────────────────────────────────────────────

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=4000
API_HOST=0.0.0.0
API_BASE_URL=http://localhost:4000

# ── Base de datos ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/simplev2

# ── CORS ──────────────────────────────────────────────────────────────────────
# Orígenes permitidos separados por coma
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost:3005

# ── Autenticación ─────────────────────────────────────────────────────────────
SESSION_SECRET=simple_v2_local_dev_secret_change_me
AUTH_COOKIE_SAMESITE=lax
# Solo desarrollo: `true` eleva el rol de sesión a superadmin (probar admin global). Por defecto desactivado — si no, otras apps verían rol incorrecto.
LOCAL_DEV_FORCE_SUPERADMIN=false

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Puede apuntar al API o al callback frontend de cada app.
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
# Google Calendar (Simple Serenatas): {API_BASE_URL}/api/serenatas/google-calendar/callback
SERENATAS_APP_URL=http://localhost:3005

# ── Storage Provider ──────────────────────────────────────────────────────────
# DEFAULT DEV: local — archivos en services/api/uploads, URLs http://localhost:4000/uploads/*
# No requiere bucket ni credenciales R2 para Simple Serenatas ni el resto de apps.
STORAGE_PROVIDER=local
# URL pública de archivos locales (solo si STORAGE_PROVIDER=local)
LOCAL_STORAGE_URL=http://localhost:4000/uploads

# ── Storage — Cloudflare R2 (OPCIONAL en dev; descomenta las 5 vars + STORAGE_PROVIDER=cloudflare-r2)
# Credenciales: Dashboard → R2 → Manage R2 API Tokens (permiso Object Read & Write).
# Si falta alguna variable, el factory vuelve a local en NODE_ENV=development.
# CLOUDFLARE_R2_ACCOUNT_ID=          # 1/5 — ID de cuenta Cloudflare (no el nombre del bucket)
# CLOUDFLARE_R2_ACCESS_KEY_ID=       # 2/5
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=   # 3/5
# CLOUDFLARE_R2_BUCKET_NAME=simple-media   # 4/5
# CLOUDFLARE_R2_PUBLIC_URL=https://pub-XXXXXXXX.r2.dev   # 5/5 — Public access (*.r2.dev o custom domain)
# Sin PUBLIC_URL los uploads a R2 no se ven en <img>; con STORAGE_PROVIDER=local no hace falta.
# Worker de overlays Instagram (opcional; ver infrastructure/cloudflare/workers/instagram-overlay/)
# CLOUDFLARE_WORKER_URL=https://simple-instagram-overlay.<tu-subdominio>.workers.dev
# Verificar bucket (requiere wrangler login): wrangler r2 bucket list
#   wrangler r2 object list simple-media --limit 5

# ── Google Maps (geocodificación server-side) ─────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ── SMTP (Brevo) ──────────────────────────────────────────────────────────────
# Mismo remitente que producción: noreply@simpleplataforma.app (todas las verticales).
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Simple <noreply@simpleplataforma.app>

# ── Mercado Pago ──────────────────────────────────────────────────────────────
# Access token de la cuenta vendedora (real en producción, TEST-... en sandbox).
MERCADO_PAGO_ACCESS_TOKEN=
# Secret del webhook (panel de Mercado Pago → Configuración → Notificaciones).
# Si está vacío en local, la verificación de firma queda deshabilitada y solo se
# usa la consulta a `getPaymentById` como segunda barrera. **Obligatorio en producción.**
MERCADO_PAGO_WEBHOOK_SECRET=
# Solo desarrollo local: webhooks sin firma HMAC
MERCADO_PAGO_WEBHOOK_ALLOW_UNSIGNED=
# Orígenes públicos de cada app (back_urls de Checkout Pro).
MERCADO_PAGO_PUBLIC_ORIGIN_AUTOS=http://localhost:3002
MERCADO_PAGO_PUBLIC_ORIGIN_PROPIEDADES=http://localhost:3003
MERCADO_PAGO_PUBLIC_ORIGIN_SERENATAS=http://localhost:3005
MERCADO_PAGO_DEV_CHECKOUT_FALLBACK=true

# Serenatas marketplace primario; true solo si necesitas paquetes legacy + MP.
SERENATAS_LEGACY_PACKAGES=false

# ── SimpleAgenda — Mercado Pago OAuth ─────────────────────────────────────────
MP_AGENDA_APP_ID=
MP_AGENDA_APP_SECRET=
AGENDA_APP_URL=http://localhost:3004

# ── WhatsApp (Meta Business) ──────────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_PHONE_NUMBER_ID_AUTOS=
WHATSAPP_PHONE_NUMBER_ID_PROPIEDADES=
WHATSAPP_PHONE_NUMBER_ID_AGENDA=

# ── Instagram ─────────────────────────────────────────────────────────────────
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=https://api.simpleplataforma.app/api/integrations/instagram/callback

# ── Cron jobs ─────────────────────────────────────────────────────────────────
# En producción los crons se activan automáticamente. En local, ponlo en `true`
# si quieres probar los recordatorios de SimpleAgenda.
AGENDA_CRON_ENABLED=false

# ── Admin bootstrap ───────────────────────────────────────────────────────────
# Habilita endpoint para crear el primer superadmin. Riesgo: elevación de privilegios si el API
# queda expuesto (staging compartido, túneles, etc.). Usar solo en local aislado.
ENABLE_ADMIN_BOOTSTRAP=false
